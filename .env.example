# Copy this file to .env and fill in values

# Anthropic Claude API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL (change in production)
DATABASE_URL=postgresql+asyncpg://cdss_user:cdss_pass@localhost:5432/cdss_db

# Redis
REDIS_URL=redis://localhost:6379

# Security — use a long random string in production
SECRET_KEY=change-this-in-production

# Debug mode
DEBUG=true

# Frontend access password (set this in Render environment variables)
VITE_APP_PASSWORD=
